---
import '../styles/global.css';
import CursorGlow from '../components/CursorGlow.astro';
import GlowCard from '../components/GlowCard.astro';

const links = {
	linkedin: 'https://www.linkedin.com/in/tanay-lodh/',
	substack: 'https://substack.com/@tonoooooy',
	resume: '/resume',
};

const greeting = "Hello, I'm";
const nameEnglish = 'Tonoy';
const nameBengali = 'তনয়';
const tagline = 'Engineering, Visuals and Thoughts. Exploring the intersection of tech and the creative.';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Tonoy — Engineering, Visuals and Thoughts</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&family=Noto+Serif+Bengali:wght@400;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="min-h-screen bg-background font-body grid-pattern">
		<CursorGlow />
		<div class="grid-reflection"></div>
		<main class="mx-auto flex min-h-screen max-w-[1200px] flex-col justify-center px-6 py-20 md:px-12 lg:px-[48px]">
			<section class="w-full">
				<div class="flex flex-col gap-6 text-left lg:gap-[24px]">
					<p class="text-lg text-muted">{greeting}</p>
					<div class="flex items-end justify-start gap-5 lg:gap-[25px]">
						<h1 class="font-display text-[clamp(2.5rem,8vw,4rem)] font-bold leading-tight text-primary">{nameEnglish}</h1>
						<span class="font-bengali text-[clamp(1.25rem,4vw,1.875rem)] font-semibold leading-tight text-muted">{nameBengali}</span>
					</div>
					<p class="font-display text-lg leading-relaxed text-foreground lg:text-xl">{tagline}</p>
				</div>

				<div class="mt-12 flex flex-wrap items-center justify-start gap-4 lg:mt-[48px]">
					<GlowCard as="a" href={links.linkedin} target="_blank" rel="noopener noreferrer">
						<span class="inline-flex items-center gap-2 rounded-md bg-secondary/80 backdrop-blur-sm px-6 py-3 text-sm font-medium text-foreground ring-1 ring-foreground/12 transition-all duration-200 hover:glow-secondary-hover hover:ring-primary/30">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a3 3 0 0 0-3-3 3 3 0 0 0-3 3v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
							LinkedIn
						</span>
					</GlowCard>
					<GlowCard as="a" href={links.substack} target="_blank" rel="noopener noreferrer">
						<span class="inline-flex items-center gap-2 rounded-md bg-secondary/80 backdrop-blur-sm px-6 py-3 text-sm font-medium text-foreground ring-1 ring-foreground/12 transition-all duration-200 hover:glow-secondary-hover hover:ring-primary/30">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
							Substack
						</span>
					</GlowCard>
					<GlowCard as="a" href={links.resume}>
						<span class="inline-flex items-center gap-2 rounded-md bg-primary/85 backdrop-blur-sm px-6 py-3 text-sm font-medium text-primary-foreground ring-1 ring-primary/50 glow-button transition-all duration-200 hover:glow-button-hover hover:ring-primary/80">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
							Resume
						</span>
					</GlowCard>
				</div>
			</section>
		</main>
	</body>
</html>
