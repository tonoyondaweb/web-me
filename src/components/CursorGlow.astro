---
---

<div class="cursor-dot"></div>
<div class="cursor-halo"></div>

<script>
	const isTouchDevice =
		window.matchMedia('(hover: none) and (pointer: coarse)').matches;

	const glowCards = Array.from(document.querySelectorAll('[data-glow-card]'));

	const updateGlowCards = (cx, cy) => {
		for (let i = 0; i < glowCards.length; i++) {
			const card = glowCards[i];
			const rect = card.getBoundingClientRect();
			const x = cx - rect.left;
			const y = cy - rect.top;
			card.style.setProperty('--glow-mx', `${x}px`);
			card.style.setProperty('--glow-my', `${y}px`);
		}
	};

	if (isTouchDevice) {
		document.documentElement.style.cursor = '';

		const gridReflection = document.querySelector('.grid-reflection');

		document.addEventListener(
			'touchmove',
			(e) => {
				const touch = e.touches[0];
				if (touch) {
					if (gridReflection) gridReflection.style.opacity = '1';
					updateGlowCards(touch.clientX, touch.clientY);
					document.documentElement.style.setProperty('--cursor-x', `${touch.clientX}px`);
					document.documentElement.style.setProperty('--cursor-y', `${touch.clientY}px`);
				}
			},
			{ passive: true }
		);

		document.addEventListener(
			'touchend',
			() => {
				for (let i = 0; i < glowCards.length; i++) {
					glowCards[i].style.setProperty('--glow-mx', '-9999px');
					glowCards[i].style.setProperty('--glow-my', '-9999px');
				}
				document.documentElement.style.setProperty('--cursor-x', '-9999px');
				document.documentElement.style.setProperty('--cursor-y', '-9999px');
				if (gridReflection) gridReflection.style.opacity = '0';
			},
			{ passive: true }
		);
	} else {
		document.documentElement.style.cursor = 'none';

		const dot = document.querySelector('.cursor-dot');
		const halo = document.querySelector('.cursor-halo');
		const gridReflection = document.querySelector('.grid-reflection');

		let mouseX = window.innerWidth / 2;
		let mouseY = window.innerHeight / 2;
		let dotX = mouseX;
		let dotY = mouseY;
		let needsUpdate = true;
		let isInWindow = true;
		let isHoveringInteractive = false;

		const interactiveSelector = 'a, button, [role="button"], input, textarea, select';

		const updateVisibility = () => {
			const visible = isInWindow && !isHoveringInteractive;
			dot.style.opacity = visible ? '1' : '0';
			halo.style.opacity = visible ? '1' : '0';
			if (gridReflection) gridReflection.style.opacity = isInWindow ? '1' : '0';
			document.documentElement.style.cursor = visible ? 'none' : '';
		};

		const animate = () => {
			if (needsUpdate) {
				const ease = 0.3;
				dotX += (mouseX - dotX) * ease;
				dotY += (mouseY - dotY) * ease;

				dot.style.transform = `translate3d(${dotX - 16}px, ${dotY - 16}px, 0)`;
				halo.style.transform = `translate3d(${dotX - 200}px, ${dotY - 200}px, 0)`;

				document.documentElement.style.setProperty('--cursor-x', `${dotX}px`);
				document.documentElement.style.setProperty('--cursor-y', `${dotY}px`);

				updateGlowCards(dotX, dotY);

				needsUpdate = false;
			}

			requestAnimationFrame(animate);
		};

		document.addEventListener(
			'mousemove',
			(e) => {
				mouseX = e.clientX;
				mouseY = e.clientY;
				needsUpdate = true;
			},
			{ passive: true }
		);

		document.addEventListener(
			'mouseover',
			(e) => {
				const target = e.target.closest(interactiveSelector);
				if (target) {
					isHoveringInteractive = true;
					target.classList.add('cursor-hover');
					updateVisibility();
				}
			},
			true
		);

		document.addEventListener(
			'mouseout',
			(e) => {
				const target = e.target.closest(interactiveSelector);
				if (target) {
					isHoveringInteractive = false;
					target.classList.remove('cursor-hover');
					updateVisibility();
				}
			},
			true
		);

		window.addEventListener('blur', () => {
			isInWindow = false;
			updateVisibility();
		});

		window.addEventListener('focus', () => {
			isInWindow = true;
			updateVisibility();
		});

		document.documentElement.addEventListener('mouseleave', () => {
			isInWindow = false;
			updateVisibility();
		});

		document.documentElement.addEventListener('mouseenter', () => {
			isInWindow = true;
			updateVisibility();
		});

		requestAnimationFrame(animate);
	}
</script>

<style is:global>
	html,
	html *,
	a,
	button,
	[role="button"],
	input,
	textarea,
	select {
		cursor: none !important;
	}

	.cursor-dot,
	.cursor-halo {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		will-change: transform;
	}

	.cursor-dot {
		width: 32px;
		height: 32px;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(212, 185, 155, 0.7) 0%,
			rgba(212, 185, 155, 0.25) 50%,
			transparent 70%
		);
		transition: opacity 200ms ease-out;
		z-index: 10000;
	}

	.cursor-halo {
		width: 400px;
		height: 400px;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(212, 185, 155, 0.06) 0%,
			rgba(212, 185, 155, 0.02) 40%,
			transparent 70%
		);
		transition: opacity 200ms ease-out;
		z-index: 9999;
	}

	@media (hover: none) and (pointer: coarse) {
		.cursor-dot,
		.cursor-halo {
			display: none !important;
		}
	}
</style>
